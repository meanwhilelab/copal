# Amber core configuration — copy to .env and fill in
DATABASE_URL=postgres://amber:amber@localhost:5433/amber
PORT=8787
HOST=0.0.0.0
# Comma-free plain values; never commit real tokens.

# Housekeeper (step 4) — omit keys to leave jobs queued.
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=            # only needed with HOUSEKEEPER_PROVIDER=anthropic
# HOUSEKEEPER_PROVIDER=gemini   # gemini | anthropic
# HOUSEKEEPER_MODEL=gemini-3.1-flash-lite
# HOUSEKEEPER_DAILY_CAP_EUR=1.0
